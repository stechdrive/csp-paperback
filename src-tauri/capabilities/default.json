{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Permissions for the main CSP Paperback window. File access is limited to user-selected paths from native dialogs and app-specific directories.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-center",
    "core:window:allow-close",
    "core:window:allow-set-resizable",
    "core:window:allow-set-size",
    "core:window:allow-set-title",
    "dialog:default",
    "fs:default",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://github.com/stechdrive/csp-paperback/releases*"
        }
      ]
    }
  ]
}
